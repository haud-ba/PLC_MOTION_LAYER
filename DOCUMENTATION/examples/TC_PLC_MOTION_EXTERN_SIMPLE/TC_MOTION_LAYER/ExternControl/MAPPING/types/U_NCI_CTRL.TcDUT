<TcPlcObject Version="1.1.0.1">
  <DUT Name="U_NCI_CTRL" Id="{fa54023e-59cd-4eab-81db-e55539e763db}">
    <Declaration><![CDATA[TYPE U_NCI_CTRL :
UNION

  stCtrl              : ARRAY[1..MAX_NCI_CH] OF ST_NCI_CTRL;

  byCtrl    AT %q*    : ARRAY[1..MAX_NCI_CH] OF
                        ARRAY[1..SIZEOF(ST_NCI_CTRL)] OF BYTE;
END_UNION
END_TYPE
]]></Declaration>
  </DUT>
