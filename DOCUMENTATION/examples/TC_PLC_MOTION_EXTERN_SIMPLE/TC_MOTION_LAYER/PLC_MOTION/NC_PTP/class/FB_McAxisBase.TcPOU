    <Method Name="Cycle" Id="{0952ac4a-b64d-0779-0df8-f45840c5c7eb}" FolderPath="methods\">
      <Declaration><![CDATA[METHOD Cycle : E_PROGRESS
VAR_INST
  _eState           : E_PROGRESS;
  _rValue           : LREAL;
  _stMsg            : ST_Message;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT (__ISVALIDREF(_AxisRef))
THEN
  Cycle                           := E_PROGRESS.PROGRESS_ERROR;
  RETURN;
END_IF

// call cyclic NC interface
_AxisRef();

_fbPower(
        Axis                      := _AxisRef, 
        Enable_Positive           := _bEnablePositive, 
        Enable_Negative           := _bEnableNegative, 
        Override                  := _rAxisOverride);

CASE _eState
OF
  E_PROGRESS.PROGRESS_INVALID:
    _fbGetCurTaskIndex();
    _rCycleTime                   := UDINT_TO_LREAL(_TaskInfo[_fbGetCurTaskIndex.index].CycleTime)/10000.0;

    _eState                       := E_PROGRESS.PROGRESS_BUSY;
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_BUSY:
    IF (_fbPower.Error) OR
       (_AxisRef.Status.Error)
    THEN
      _eState                     := E_PROGRESS.PROGRESS_ERROR;

      _nErrorId                   := SEL((_fbPower.ErrorID > 0), _AxisRef.NcToPlc.ErrorCode, _fbPower.ErrorID);

      IF (_nErrorId <> _stMsg.iErrorNumber)
      THEN
        _stMsg.eType                := E_MessageType.eMessageError;
        _stMsg.eDevice              := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);;
        _stMsg.eSubdevice           := e_Subdevice.AxisCycle;
        _stMsg.iErrorNumber         := _nErrorId;
  
        _stMsg.sText                := concat(' : ', TO_STRING(_eState));
  
        f_MessageSet(_stMsg);
      END_IF
    ELSE
      _eState                     := E_PROGRESS.PROGRESS_WORKING;
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_WORKING:
    // rinse, repeat
    _eState                       := E_PROGRESS.PROGRESS_BUSY;
    Cycle                         := E_PROGRESS.PROGRESS_WORKING;
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_ERROR:
    IF NOT (_fbPower.Error)
    THEN
      _eState                     := E_PROGRESS.PROGRESS_BUSY;
    ELSE
      Cycle                       := E_PROGRESS.PROGRESS_ERROR;
    END_IF
END_CASE


]]></ST>
      </Implementation>
    </Method>
    <Method Name="Disable" Id="{3cfd1816-2e58-0ba6-30c2-feff57d138a8}" FolderPath="methods\">
      <Declaration><![CDATA[METHOD Disable : E_PROGRESS
VAR_INPUT
  Execute           : BOOL;
END_VAR
VAR_INST
  _eResult,
  _eState           : E_PROGRESS;
  _rValue           : LREAL;
  _stMsg            : ST_Message;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT (__ISVALIDREF(_AxisRef)) THEN  Disable  := E_PROGRESS.PROGRESS_ERROR; RETURN; END_IF
IF NOT Execute THEN _eState := E_PROGRESS.PROGRESS_INIT; END_IF

CASE _eState
OF
  E_PROGRESS.PROGRESS_INIT:
    IF Execute 
    THEN
      memset(ADR(_stMsg),0,SIZEOF(_stMsg));
      _nErrorId                     := 0;
      _rValue                       := 0;
      _eState                       := E_PROGRESS.PROGRESS_BUSY;
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_BUSY:
    _fbPower.Enable                 := FALSE;
    _eResult                        := Reset(FALSE);
    _eState                         := E_PROGRESS.PROGRESS_STARTUP;

  E_PROGRESS.PROGRESS_STARTUP:
    IF _fbPower.Error OR
       _AxisRef.Status.Error
    THEN
      _eState                       := E_PROGRESS.PROGRESS_PREPARE;

      _stMsg.eType                  := E_MessageType.eMessageVerbose;
      _stMsg.eDevice                := E_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             := e_Subdevice.fbPower;
      _stMsg.iErrorNumber           := 0;

      _stMsg.sText                  := concat('clear error on disable : ', TO_STRING(_eState));

      IF (_MessageLevel = E_MessageType.eMessageVerbose)
      THEN
        f_MessageSet(_stMsg);
      END_IF
    ELSE
      _eState                       := E_PROGRESS.PROGRESS_OCCUPIED;
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_PREPARE:
    _eResult                        := Reset(TRUE);
    IF (_eResult = E_PROGRESS.PROGRESS_DONE)
    THEN
      _eState                       := E_PROGRESS.PROGRESS_OCCUPIED;

      _stMsg.eType                  := E_MessageType.eMessageVerbose;
      _stMsg.eDevice                := E_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             := e_Subdevice.fbPower;
      _stMsg.iErrorNumber           := 0;

      _stMsg.sText                  := concat('clear error on disable : ', TO_STRING(_eResult));

      IF (_MessageLevel = E_MessageType.eMessageVerbose)
      THEN
        f_MessageSet(_stMsg);
      END_IF
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_OCCUPIED:
    IF _AxisRef.Status.Error
    THEN
      _nErrorId                     := _AxisRef.NcToPlc.ErrorCode;
    
      _stMsg.eType                  := E_MessageType.eMessageError;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             :=  e_SubDevice.fbPower;
      _stMsg.iErrorNumber           := _nErrorId;

      f_MessageSet(_stMsg);
    
      _eState                       := E_PROGRESS.PROGRESS_ERROR;

    ELSIF NOT _AxisRef.Status.ControlLoopClosed
    THEN
      _eState                       := E_PROGRESS.PROGRESS_WORKING;
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_WORKING:
    _eResult                        := Reset(FALSE);
    _eState                         := E_PROGRESS.PROGRESS_DONE;

      _stMsg.eType                  := E_MessageType.eMessageVerbose;
      _stMsg.eDevice                := E_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             := e_Subdevice.fbPower;
      _stMsg.iErrorNumber           := 0;

      _stMsg.sText                  := concat(' : ', TO_STRING(_eState));

      IF (_MessageLevel = E_MessageType.eMessageVerbose)
      THEN
        f_MessageSet(_stMsg);
      END_IF
END_CASE

Disable                             := _eState;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="Enable" Id="{d3ecb8f6-2a8a-08cc-230d-f8b28d0b2674}" FolderPath="methods\">
      <Declaration><![CDATA[METHOD Enable : E_PROGRESS
VAR_INPUT
  Execute           : BOOL;
END_VAR
VAR_INST
  _eResult,
  _eState           : E_PROGRESS;
  _rValue           : LREAL;
  _stMsg            : ST_Message;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT (__ISVALIDREF(_AxisRef)) THEN  Enable  := E_PROGRESS.PROGRESS_ERROR; RETURN; END_IF
IF NOT Execute THEN _eState := E_PROGRESS.PROGRESS_INIT; END_IF

CASE _eState
OF
  E_PROGRESS.PROGRESS_INIT:
    IF Execute 
    THEN
      memset(ADR(_stMsg),0,SIZEOF(_stMsg));
      _nErrorId                     := 0;
      _rValue                       := 0;
      _eState                       := E_PROGRESS.PROGRESS_BUSY;
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_BUSY:
    _fbPower.Enable                 := TRUE;
    _eResult                        := Reset(FALSE);
    _eState                         := E_PROGRESS.PROGRESS_STARTUP;

  E_PROGRESS.PROGRESS_STARTUP:
    IF _fbPower.Error OR
       _AxisRef.Status.Error
    THEN
      _eState                       := E_PROGRESS.PROGRESS_PREPARE;

      _stMsg.eType                  := E_MessageType.eMessageVerbose;
      _stMsg.eDevice                := E_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             := e_Subdevice.fbPower;
      _stMsg.iErrorNumber           := 0;

      _stMsg.sText                  := concat('clear error on enable : ', TO_STRING(_eState));

      IF (_MessageLevel = E_MessageType.eMessageVerbose)
      THEN
        f_MessageSet(_stMsg);
      END_IF
    ELSE
      _eState                       := E_PROGRESS.PROGRESS_OCCUPIED;
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_PREPARE:
    _eResult                        := Reset(TRUE);
    IF (_eResult = E_PROGRESS.PROGRESS_DONE)
    THEN
      _eState                       := E_PROGRESS.PROGRESS_OCCUPIED;
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_OCCUPIED:
    IF _AxisRef.Status.Error
    THEN
      _nErrorId                     := _AxisRef.NcToPlc.ErrorCode;
    
      _stMsg.eType                  := E_MessageType.eMessageError;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             :=  e_SubDevice.fbPower;
      _stMsg.iErrorNumber           := _nErrorId;
    
      f_MessageSet(_stMsg);

      _eState                       := E_PROGRESS.PROGRESS_ERROR;

    ELSIF _AxisRef.Status.ControlLoopClosed
    THEN
      _eState                       := E_PROGRESS.PROGRESS_WORKING;
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_WORKING:
    _eResult                        := Reset(FALSE);
    _eState                         := E_PROGRESS.PROGRESS_DONE;

      _stMsg.eType                  := E_MessageType.eMessageVerbose;
      _stMsg.eDevice                := E_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             := e_Subdevice.fbPower;
      _stMsg.iErrorNumber           := 0;

      _stMsg.sText                  := concat(' : ', TO_STRING(_eState));

      IF (_MessageLevel = E_MessageType.eMessageVerbose)
      THEN
        f_MessageSet(_stMsg);
      END_IF
END_CASE

Enable                              := _eState;
]]></ST>
      </Implementation>
    </Method>
