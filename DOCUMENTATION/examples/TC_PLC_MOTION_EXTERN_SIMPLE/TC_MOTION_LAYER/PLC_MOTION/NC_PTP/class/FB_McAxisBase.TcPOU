    <Method Name="MovePosBuffer" Id="{c85dc519-a612-0a41-1a3d-8c9a1d3f1397}" FolderPath="methods\">
      <Declaration><![CDATA[METHOD MovePosBuffer : E_PROGRESS
VAR_INPUT
  bEnable          : BOOL;
  Position        : LREAL;
  Vel             : LREAL;
  Acc             : LREAL;
  Dec             : LREAL;
  Jerk            : LREAL;
  BufferMode      : Tc2_MC2.MC_BufferMode;
END_VAR
VAR_INST
  _eState           : E_PROGRESS;
  _rValue           : LREAL;
  _stMsg            : ST_Message;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT (__ISVALIDREF(_AxisRef)) THEN  MovePosBuffer  := E_PROGRESS.PROGRESS_ERROR; RETURN; END_IF
IF NOT bEnable THEN _eState := E_PROGRESS.PROGRESS_INIT; END_IF

CASE _eState
OF
  E_PROGRESS.PROGRESS_INIT:
    IF bEnable 
    THEN
      memset(ADR(_stMsg),0,SIZEOF(_stMsg));
      _nErrorId                     := 0;
      _rValue                       := Position;

      _eState                       := E_PROGRESS.PROGRESS_BUSY;

      _stMsg.eType                  := E_MessageType.eMessageVerbose;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             := e_SubDevice.fbMoveAbsolute1;
      _stMsg.iErrorNumber           := 0;

      _stMsg.sText                  := concat('FB start : ', TO_STRING(_rValue));

      IF (_MessageLevel = E_MessageType.eMessageVerbose)
      THEN
        f_MessageSet(_stMsg);
      END_IF
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_BUSY:
    _eState                         := E_PROGRESS.PROGRESS_STARTUP;
    _fbMoveAbsolute[1](
                    Axis            := _AxisRef,
                    Execute         := FALSE);

    _fbMoveAbsolute[2](
                    Axis            := _AxisRef,
                    Execute         := FALSE);

END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_STARTUP:
    _fbMoveAbsolute[1](
                    Axis            := _AxisRef, 
                    Execute         := TRUE,
                    Position        := _rValue, 
                    Velocity        := Vel, 
                    Acceleration    := Acc, 
                    Deceleration    := Dec, 
                    Jerk            := Jerk, 
                    BufferMode      := BufferMode);

    _fbMoveAbsolute[2](
                    Axis            := _AxisRef,
                    Execute         := FALSE);

    _rLastTargetPosition            := _fbMoveAbsolute[1].Position;

    IF _fbMoveAbsolute[1].Error
    THEN
      _eState                       := E_PROGRESS.PROGRESS_ERROR;
      _nErrorId                     := _fbMoveAbsolute[1].ErrorID;
    
      _stMsg.eType                  := E_MessageType.eMessageError;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             :=  e_SubDevice.fbMoveAbsolute1;
      _stMsg.iErrorNumber           := _nErrorId;
    
      _stMsg.sText                  := concat(' : ', TO_STRING(_eState));
    
      f_MessageSet(_stMsg);

    ELSIF (_fbMoveAbsolute[1].Busy)
    THEN
      _eState                       := E_PROGRESS.PROGRESS_PREPARE;

      _stMsg.eType                  := E_MessageType.eMessageVerbose;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             :=  e_SubDevice.fbMoveAbsolute1;
      _stMsg.iErrorNumber           := 0;

      _stMsg.sText                  := concat('FB busy: ', TO_STRING(_eState));

      IF (_MessageLevel = E_MessageType.eMessageVerbose)
      THEN
        f_MessageSet(_stMsg);
      END_IF

    ELSIF (_fbMoveAbsolute[1].CommandAborted)
    THEN
      _eState                       := E_PROGRESS.PROGRESS_PREPARE;

      _stMsg.eType                  := E_MessageType.eMessageVerbose;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             :=  e_SubDevice.fbMoveAbsolute1;
      _stMsg.iErrorNumber           := 0;

      _stMsg.sText                  := concat('FB aborted: ', TO_STRING(_eState));

      IF (_MessageLevel = E_MessageType.eMessageVerbose)
      THEN
        f_MessageSet(_stMsg);
      END_IF

    ELSIF (_fbMoveAbsolute[1].Done)
    THEN
      _eState                       := E_PROGRESS.PROGRESS_PREPARE;

      _stMsg.eType                  := E_MessageType.eMessageVerbose;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             :=  e_SubDevice.fbMoveAbsolute1;
      _stMsg.iErrorNumber           := 0;

      _stMsg.sText                  := concat('FB done: ', TO_STRING(_eState));

      IF (_MessageLevel = E_MessageType.eMessageVerbose)
      THEN
        f_MessageSet(_stMsg);
      END_IF
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_PREPARE:
    _fbMoveAbsolute[1](
                    Axis            := _AxisRef);
    _fbMoveAbsolute[2](
                    Axis            := _AxisRef,
                    Execute         := FALSE);

    IF _fbMoveAbsolute[1].Error
    THEN
      _eState                       := E_PROGRESS.PROGRESS_ERROR;
      _nErrorId                     := _fbMoveAbsolute[1].ErrorID;
    
      _stMsg.eType                  := E_MessageType.eMessageError;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             :=  e_SubDevice.fbMoveAbsolute1;
      _stMsg.iErrorNumber           := _nErrorId;
    
      _stMsg.sText                  := concat(' : ', TO_STRING(_eState));
    
      f_MessageSet(_stMsg);

    ELSIF (Position <> _rValue)
    THEN
      IF _fbMoveAbsolute[1].Active
      THEN
        _fbMoveAbsolute[1](
                    Axis            := _AxisRef, 
                    Execute         := FALSE);
  
        _eState                       := E_PROGRESS.PROGRESS_CHECK;
  
        _stMsg.eType                  := E_MessageType.eMessageVerbose;
        _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
        _stMsg.eSubdevice             :=  e_SubDevice.fbMoveAbsolute2;
        _stMsg.iErrorNumber           := 0;
  
        _stMsg.sText                  := concat('Position changed: ', TO_STRING(_rValue));
        _stMsg.sText                  := concat(_stMsg.sText        , ' to ');
        _stMsg.sText                  := concat(_stMsg.sText        , TO_STRING(Position));
  
        IF (_MessageLevel = E_MessageType.eMessageVerbose)
        THEN
          f_MessageSet(_stMsg);
        END_IF

        _rValue                       := Position;
      END_IF
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_CHECK:
    _fbMoveAbsolute[1](
                    Axis            := _AxisRef,
                    Execute         := FALSE);

    _fbMoveAbsolute[2](
                    Axis            := _AxisRef, 
                    Execute         := TRUE,
                    Position        := _rValue, 
                    Velocity        := Vel, 
                    Acceleration    := Acc, 
                    Deceleration    := Dec, 
                    Jerk            := Jerk, 
                    BufferMode      := BufferMode);

    _rLastTargetPosition            := _fbMoveAbsolute[2].Position;

    IF _fbMoveAbsolute[2].Error
    THEN
      _eState                       := E_PROGRESS.PROGRESS_ERROR;
      _nErrorId                     := _fbMoveAbsolute[2].ErrorID;
    
      _stMsg.eType                  := E_MessageType.eMessageError;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             :=  e_SubDevice.fbMoveAbsolute2;
      _stMsg.iErrorNumber           := _nErrorId;
    
      _stMsg.sText                  := concat(' : ', TO_STRING(_eState));
    
      f_MessageSet(_stMsg);

    ELSIF (_fbMoveAbsolute[2].Busy)
    THEN
      _eState                       := E_PROGRESS.PROGRESS_OCCUPIED;

      _stMsg.eType                  := E_MessageType.eMessageVerbose;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             :=  e_SubDevice.fbMoveAbsolute2;
      _stMsg.iErrorNumber           := 0;

      _stMsg.sText                  := concat('FB busy: ', TO_STRING(_eState));

      IF (_MessageLevel = E_MessageType.eMessageVerbose)
      THEN
        f_MessageSet(_stMsg);
      END_IF

    ELSIF (_fbMoveAbsolute[2].CommandAborted)
    THEN
      _eState                       := E_PROGRESS.PROGRESS_OCCUPIED;

      _stMsg.eType                  := E_MessageType.eMessageVerbose;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             :=  e_SubDevice.fbMoveAbsolute2;
      _stMsg.iErrorNumber           := 0;

      _stMsg.sText                  := concat('FB aborted: ', TO_STRING(_eState));

      IF (_MessageLevel = E_MessageType.eMessageVerbose)
      THEN
        f_MessageSet(_stMsg);
      END_IF

    ELSIF (_fbMoveAbsolute[2].Done)
    THEN
      _eState                       := E_PROGRESS.PROGRESS_OCCUPIED;

      _stMsg.eType                  := E_MessageType.eMessageVerbose;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             :=  e_SubDevice.fbMoveAbsolute2;
      _stMsg.iErrorNumber           := 0;

      _stMsg.sText                  := concat('FB done: ', TO_STRING(_eState));

      IF (_MessageLevel = E_MessageType.eMessageVerbose)
      THEN
        f_MessageSet(_stMsg);
      END_IF
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_OCCUPIED:
    _fbMoveAbsolute[1](
                    Axis            := _AxisRef,
                    Execute         := FALSE);

    _fbMoveAbsolute[2](
                    Axis            := _AxisRef);

    IF _fbMoveAbsolute[2].Error
    THEN
      _eState                       := E_PROGRESS.PROGRESS_ERROR;
      _nErrorId                     := _fbMoveAbsolute[2].ErrorID;
    
      _stMsg.eType                  := E_MessageType.eMessageError;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             :=  e_SubDevice.fbMoveAbsolute2;
      _stMsg.iErrorNumber           := _nErrorId;
    
      _stMsg.sText                  := concat(' : ', TO_STRING(_eState));
    
      f_MessageSet(_stMsg);

    ELSIF (Position <> _rValue)
    THEN
      IF _fbMoveAbsolute[2].Active
      THEN
        _fbMoveAbsolute[2](Axis       := _AxisRef,
                           Execute    := FALSE);
  
        _eState                       := E_PROGRESS.PROGRESS_STARTUP;
  
        _stMsg.eType                  := E_MessageType.eMessageVerbose;
        _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
        _stMsg.eSubdevice             :=  e_SubDevice.fbMoveAbsolute1;
        _stMsg.iErrorNumber           := 0;
  
        _stMsg.sText                  := concat('Position changed: ', TO_STRING(_rValue));
        _stMsg.sText                  := concat(_stMsg.sText        , ' to ');
        _stMsg.sText                  := concat(_stMsg.sText        , TO_STRING(Position));
  
        IF (_MessageLevel = E_MessageType.eMessageVerbose)
        THEN
          f_MessageSet(_stMsg);
        END_IF
 
        _rValue                       := Position;
      END_IF
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_INIT,
  E_PROGRESS.PROGRESS_ERROR:
    _fbMoveAbsolute[1](
                    Axis            := _AxisRef,
                    Execute         := FALSE);

    _fbMoveAbsolute[2](
                    Axis            := _AxisRef,
                    Execute         := FALSE);
END_CASE


MovePosBuffer                       := _eState;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="MoveToPos" Id="{9983f17a-1ed1-0daf-01b6-9e9adfd03ef3}" FolderPath="methods\">
      <Declaration><![CDATA[METHOD MoveToPos : E_PROGRESS
VAR_INPUT
  Execute         : BOOL;
  Position        : LREAL;
  Vel             : LREAL;
  Acc             : LREAL;
  Dec             : LREAL;
  Jerk            : LREAL;
  BufferMode      : Tc2_MC2.MC_BufferMode;
END_VAR
VAR_INST
  _eState           : E_PROGRESS;
  _rValue           : LREAL;
  _stMsg            : ST_Message;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT (__ISVALIDREF(_AxisRef)) THEN  MoveToPos  := E_PROGRESS.PROGRESS_ERROR; RETURN; END_IF
IF NOT Execute THEN _eState := E_PROGRESS.PROGRESS_INIT; END_IF

CASE _eState
OF
  E_PROGRESS.PROGRESS_INIT:
    IF Execute 
    THEN
      memset(ADR(_stMsg),0,SIZEOF(_stMsg));
      _nErrorId                     := 0;
      _rValue                       := 0;
      _eState                       := E_PROGRESS.PROGRESS_BUSY;

      _stMsg.eType                  := E_MessageType.eMessageInfo;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             := e_SubDevice.fbMovePtP;
      _stMsg.iErrorNumber           := 0;

      _stMsg.sText                  := concat(' : ', TO_STRING(Position));

      IF (_MessageLevel > E_MessageType.eMessageError)
      THEN
        f_MessageSet(_stMsg);
      END_IF
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_BUSY:
    _eState                         := E_PROGRESS.PROGRESS_STARTUP;
    _rValue                         := Position;

    _fbMoveToPosition(
                    Axis            := _AxisRef,
                    Execute         := FALSE);
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_STARTUP:
    _eState                         := E_PROGRESS.PROGRESS_PREPARE;
    _fbMoveToPosition(
                    Axis            := _AxisRef, 
                    Execute         := TRUE,
                    Position        := _rValue, 
                    Velocity        := Vel, 
                    Acceleration    := Acc, 
                    Deceleration    := Dec, 
                    Jerk            := Jerk, 
                    BufferMode      := BufferMode);

    _rLastTargetPosition            := _fbMoveToPosition.Position;
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_PREPARE:
    _fbMoveToPosition(
                    Axis            := _AxisRef);

    IF (_fbMoveToPosition.Error)
    THEN
      _eState                       := E_PROGRESS.PROGRESS_ERROR;
      _nErrorId                     := _fbMoveToPosition.ErrorID;
    
      _stMsg.eType                  := E_MessageType.eMessageError;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             :=  e_SubDevice.fbMovePtP;
      _stMsg.iErrorNumber           := _nErrorId;

      _stMsg.sText                  := concat(' : ', TO_STRING(_eState));
    
      f_MessageSet(_stMsg);

    ELSIF (_fbMoveToPosition.CommandAborted)
    THEN
      _eState                       := E_PROGRESS.PROGRESS_ERROR;
      _nErrorId                     := _fbMoveToPosition.ErrorID;

      _stMsg.eType                  := E_MessageType.eMessageError;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             := e_SubDevice.fbMovePtP;
      _stMsg.iErrorNumber           := _nErrorId;

      _stMsg.sText                  := concat('FB aborted: ', TO_STRING(_eState));

      f_MessageSet(_stMsg);

    ELSIF (_fbMoveToPosition.Active)
    THEN
      _eState                       := E_PROGRESS.PROGRESS_OCCUPIED;

      _stMsg.eType                  := E_MessageType.eMessageVerbose;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             := e_SubDevice.fbMovePtP;
      _stMsg.iErrorNumber           := 0;

      _stMsg.sText                  := concat('FB active: ', TO_STRING(_eState));

      IF (_MessageLevel = E_MessageType.eMessageVerbose)
      THEN
        f_MessageSet(_stMsg);
      END_IF

    ELSIF (_fbMoveToPosition.Done)
    THEN
      _eState                       := E_PROGRESS.PROGRESS_STILL_WORKING;
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_OCCUPIED:
    _fbMoveToPosition(
                    Axis            := _AxisRef);

    IF (_fbMoveToPosition.Error)
    THEN
      _eState                       := E_PROGRESS.PROGRESS_ERROR;
      _nErrorId                     := _fbMoveToPosition.ErrorID;
    
      _stMsg.eType                  := E_MessageType.eMessageError;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             :=  e_SubDevice.fbMovePtP;
      _stMsg.iErrorNumber           := _nErrorId;

      _stMsg.sText                  := concat(' : ', TO_STRING(_eState));

      f_MessageSet(_stMsg);

    ELSIF (_fbMoveToPosition.CommandAborted)
    THEN
      _eState                       := E_PROGRESS.PROGRESS_ERROR;
      _nErrorId                     := _fbMoveToPosition.ErrorID;
    
      _stMsg.eType                  := E_MessageType.eMessageError;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             :=  e_SubDevice.fbMovePtP;
      _stMsg.iErrorNumber           := _nErrorId;

      _stMsg.sText                  := concat('FB aborted : ', TO_STRING(_eState));

      f_MessageSet(_stMsg);

    ELSIF (_fbMoveToPosition.Done)
    THEN
      _eState                       := E_PROGRESS.PROGRESS_STILL_WORKING;
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_STILL_WORKING:
    _eState                         := E_PROGRESS.PROGRESS_DONE;

    _fbMoveToPosition(
                  Axis              := _AxisRef,
                  Execute           := FALSE);

    _stMsg.eType                    := E_MessageType.eMessageVerbose;
    _stMsg.eDevice                  := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
    _stMsg.eSubdevice               := e_SubDevice.fbMovePtP;
    _stMsg.iErrorNumber             := 0;

    _stMsg.sText                    := concat(' : ', TO_STRING(_eState));

    IF (_MessageLevel = E_MessageType.eMessageVerbose)
    THEN
      f_MessageSet(_stMsg);
    END_IF
END_CASE

MoveToPos                           := _eState;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="MoveVelo" Id="{f336fcbe-ff7a-0e9f-3cdd-2eac3cc75bff}" FolderPath="methods\">
      <Declaration><![CDATA[METHOD MoveVelo : E_PROGRESS
VAR_INPUT
  Execute           : BOOL;
  Velocity          : LREAL;
  Acc               : LREAL;
  Dec               : LREAL;
  Jerk              : LREAL;
  Direction         : Tc2_MC2.MC_Direction := MC_Positive_Direction;
  BufferMode        : Tc2_MC2.MC_BufferMode;
END_VAR
VAR_INST
  _eState           : E_PROGRESS;
  _rValue           : LREAL;
  _stMsg            : ST_Message;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT (__ISVALIDREF(_AxisRef)) THEN  MoveVelo  := E_PROGRESS.PROGRESS_ERROR; RETURN; END_IF
IF NOT Execute THEN _eState := E_PROGRESS.PROGRESS_INIT; END_IF

CASE _eState
OF
  E_PROGRESS.PROGRESS_INIT:
    IF Execute 
    THEN
      memset(ADR(_stMsg),0,SIZEOF(_stMsg));
      _nErrorId                     := 0;
      _rValue                       := Velocity;
      _eState                       := E_PROGRESS.PROGRESS_BUSY;

      _stMsg.eType                  := E_MessageType.eMessageInfo;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             := e_SubDevice.fbMoveVelo;
      _stMsg.iErrorNumber           := 0;

      _stMsg.sText                  := concat('FB start : ', TO_STRING(_rValue));

      IF (_MessageLevel > E_MessageType.eMessageError)
      THEN
        f_MessageSet(_stMsg);
      END_IF
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_BUSY:
    _eState                         := E_PROGRESS.PROGRESS_STARTUP;
    _fbMoveVelo(
                      Axis          := _AxisRef, 
                      Execute       := FALSE, 
                      Velocity      := _rValue, 
                      Acceleration  := Acc, 
                      Deceleration  := Dec, 
                      Jerk          := Jerk, 
                      Direction     := Direction, 
                      BufferMode    := BufferMode);
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_STARTUP:
    _fbMoveVelo(
                      Axis          := _AxisRef, 
                      Execute       := TRUE);
    _eState                         := E_PROGRESS.PROGRESS_OCCUPIED;
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_OCCUPIED:
    _fbMoveVelo(
                      Axis          := _AxisRef);

    IF _fbMoveVelo.Error
    THEN
      _eState                       := E_PROGRESS.PROGRESS_ERROR;
      _nErrorId                     := _fbMoveVelo.ErrorID;
    
      _stMsg.eType                  := E_MessageType.eMessageError;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             :=  e_SubDevice.fbMoveVelo;
      _stMsg.iErrorNumber           := _nErrorId;

      _stMsg.sText                  := concat(' : ', TO_STRING(_eState));

      f_MessageSet(_stMsg);

      _fbMoveVelo(
                      Axis          := _AxisRef, 
                      Execute       := FALSE);

    ELSIF _fbMoveVelo.CommandAborted
    THEN
      _eState                       := E_PROGRESS.PROGRESS_ERROR;

      _nErrorId                     := _fbMoveVelo.ErrorID;
    
      _stMsg.eType                  := E_MessageType.eMessageError;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             :=  e_SubDevice.fbMoveVelo;
      _stMsg.iErrorNumber           := _nErrorId;

      _stMsg.sText                  := concat('FB aborted : ', TO_STRING(_eState));

      f_MessageSet(_stMsg);

      _fbMoveVelo(
                      Axis          := _AxisRef, 
                      Execute       := FALSE);
    
    ELSIF _fbMoveVelo.InVelocity
    THEN
      _eState                       := E_PROGRESS.PROGRESS_WORKING;
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_WORKING:
    _fbMoveVelo(
                      Axis          := _AxisRef, 
                      Execute       := FALSE);

    _eState                         := E_PROGRESS.PROGRESS_DONE;

    _stMsg.eType                    := E_MessageType.eMessageVerbose;
    _stMsg.eDevice                  := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
    _stMsg.eSubdevice               := e_SubDevice.fbMoveVelo;
    _stMsg.iErrorNumber             := 0;

    _stMsg.sText                    := concat('FB InVelocity : ', TO_STRING(_eState));

    IF (_MessageLevel = E_MessageType.eMessageVerbose)
    THEN
      f_MessageSet(_stMsg);
    END_IF
END_CASE


MoveVelo                            := _eState;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="MoveVeloBuffer" Id="{6580e262-5fae-068b-31a4-0bea4fa7cdc2}" FolderPath="methods\">
      <Declaration><![CDATA[METHOD MoveVeloBuffer : E_PROGRESS
VAR_INPUT
  bEnable          : BOOL;
  Velocity        : LREAL;
  Acc             : LREAL;
  Dec             : LREAL;
  Jerk            : LREAL;
  BufferMode      : Tc2_MC2.MC_BufferMode;
END_VAR
VAR_INST
  _eState           : E_PROGRESS;
  _rValue           : LREAL;
  _stMsg            : ST_Message;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT (__ISVALIDREF(_AxisRef)) THEN  MoveVeloBuffer  := E_PROGRESS.PROGRESS_ERROR; RETURN; END_IF
IF NOT bEnable THEN _eState := E_PROGRESS.PROGRESS_INIT; END_IF

CASE _eState
OF
  E_PROGRESS.PROGRESS_INIT:
    IF bEnable 
    THEN
      memset(ADR(_stMsg),0,SIZEOF(_stMsg));
      _nErrorId                     := 0;
      _rValue                       := Velocity;

      _eState                       := E_PROGRESS.PROGRESS_BUSY;

      _stMsg.eType                  := E_MessageType.eMessageVerbose;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             := e_SubDevice.fbMoveVelocity1;
      _stMsg.iErrorNumber           := 0;

      _stMsg.sText                  := concat('start : ', TO_STRING(_rValue));

      IF (_MessageLevel = E_MessageType.eMessageVerbose)
      THEN
        f_MessageSet(_stMsg);
      END_IF
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_BUSY:
    _eState                         := E_PROGRESS.PROGRESS_STARTUP;
    _fbMoveVelocity[1](Axis         := _AxisRef,
                       Execute      := FALSE);

    _fbMoveVelocity[2](Axis         := _AxisRef,
                       Execute      := FALSE);
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_STARTUP:
    _fbMoveVelocity[1](
                    Axis            := _AxisRef, 
                    Execute         := TRUE,
                    Velocity        := _rValue, 
                    Acceleration    := Acc, 
                    Deceleration    := Dec, 
                    Jerk            := Jerk, 
                    BufferMode      := BufferMode);

    IF _fbMoveVelocity[1].Error
    THEN
      _eState                       := E_PROGRESS.PROGRESS_ERROR;

      _nErrorId                     := _fbMoveVelocity[1].ErrorID;
    
      _stMsg.eType                  := E_MessageType.eMessageError;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             :=  e_SubDevice.fbMoveVelocity1;
      _stMsg.iErrorNumber           := _nErrorId;

      _stMsg.sText                  := concat(' : ', TO_STRING(_eState));
    
      f_MessageSet(_stMsg);

    ELSIF (_fbMoveVelocity[1].Busy)
    THEN
      _eState                       := E_PROGRESS.PROGRESS_PREPARE;

      _stMsg.eType                  := E_MessageType.eMessageVerbose;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             :=  e_SubDevice.fbMoveVelocity1;
      _stMsg.iErrorNumber           := 0;

      _stMsg.sText                  := concat('FB busy: ', TO_STRING(_eState));

      IF (_MessageLevel = E_MessageType.eMessageVerbose)
      THEN
        f_MessageSet(_stMsg);
      END_IF

    ELSIF (_fbMoveVelocity[1].CommandAborted)
    THEN
      _eState                       := E_PROGRESS.PROGRESS_PREPARE;

      _stMsg.eType                  := E_MessageType.eMessageError;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             :=  e_SubDevice.fbMoveVelocity1;
      _stMsg.iErrorNumber           := 0;

      _stMsg.sText                  := concat('FB aborted: ', TO_STRING(_eState));

      f_MessageSet(_stMsg);

    ELSIF (_fbMoveVelocity[1].InVelocity)
    THEN
      _eState                       := E_PROGRESS.PROGRESS_PREPARE;

      _stMsg.eType                  := E_MessageType.eMessageVerbose;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             :=  e_SubDevice.fbMoveVelocity1;
      _stMsg.iErrorNumber           := 0;

      _stMsg.sText                  := concat('FB done: ', TO_STRING(_eState));

      IF (_MessageLevel = E_MessageType.eMessageVerbose)
      THEN
        f_MessageSet(_stMsg);
      END_IF
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_PREPARE:
    _fbMoveVelocity[1](Axis         := _AxisRef);

    IF _fbMoveVelocity[1].Error
    THEN
      _eState                       := E_PROGRESS.PROGRESS_ERROR;

      _nErrorId                     := _fbMoveVelocity[1].ErrorID;
    
      _stMsg.eType                  := E_MessageType.eMessageError;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             :=  e_SubDevice.fbMoveVelocity1;
      _stMsg.iErrorNumber           := _nErrorId;

      _stMsg.sText                  := concat(' : ', TO_STRING(_eState));
    
      f_MessageSet(_stMsg);
    
    ELSIF (_fbMoveVelocity[1].Velocity <> Velocity)
    THEN
      _eState                       := E_PROGRESS.PROGRESS_CHECK;

      _fbMoveVelocity[1](
                    Axis            := _AxisRef, 
                    Execute         := FALSE);

      _stMsg.eType                  := E_MessageType.eMessageVerbose;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             :=  e_SubDevice.fbMoveVelocity2;
      _stMsg.iErrorNumber           := 0;

      _stMsg.sText                  := concat('Velocity changed: ', TO_STRING(_rValue));
      _stMsg.sText                  := concat(_stMsg.sText        , ' to ');
      _stMsg.sText                  := concat(_stMsg.sText        , TO_STRING(Velocity));

      IF (_MessageLevel = E_MessageType.eMessageVerbose)
      THEN
        f_MessageSet(_stMsg);
      END_IF

      _rValue                       := Velocity;
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_CHECK:
    _fbMoveVelocity[2](
                    Axis            := _AxisRef, 
                    Execute         := TRUE,
                    Velocity        := _rValue, 
                    Acceleration    := Acc, 
                    Deceleration    := Dec, 
                    Jerk            := Jerk, 
                    BufferMode      := BufferMode);

    IF _fbMoveVelocity[2].Error
    THEN
      _eState                       := E_PROGRESS.PROGRESS_ERROR;

      _nErrorId                     := _fbMoveVelocity[2].ErrorID;
    
      _stMsg.eType                  := E_MessageType.eMessageError;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             :=  e_SubDevice.fbMoveVelocity2;
      _stMsg.iErrorNumber           := _nErrorId;

      _stMsg.sText                  := concat(' : ', TO_STRING(_eState));
    
      f_MessageSet(_stMsg);

    ELSIF (_fbMoveVelocity[2].Busy)
    THEN
      _eState                       := E_PROGRESS.PROGRESS_OCCUPIED;

      _stMsg.eType                  := E_MessageType.eMessageVerbose;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             :=  e_SubDevice.fbMoveVelocity2;
      _stMsg.iErrorNumber           := 0;

      _stMsg.sText                  := concat('FB busy: ', TO_STRING(_eState));

      IF (_MessageLevel = E_MessageType.eMessageVerbose)
      THEN
        f_MessageSet(_stMsg);
      END_IF

    ELSIF (_fbMoveVelocity[2].CommandAborted)
    THEN
      _eState                       := E_PROGRESS.PROGRESS_OCCUPIED;

      _stMsg.eType                  := E_MessageType.eMessageError;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             :=  e_SubDevice.fbMoveVelocity2;
      _stMsg.iErrorNumber           := 0;

      _stMsg.sText                  := concat('FB aborted: ', TO_STRING(_eState));

      f_MessageSet(_stMsg);

    ELSIF (_fbMoveVelocity[2].InVelocity)
    THEN
      _eState                       := E_PROGRESS.PROGRESS_OCCUPIED;

      _stMsg.eType                  := E_MessageType.eMessageVerbose;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             :=  e_SubDevice.fbMoveVelocity2;
      _stMsg.iErrorNumber           := 0;

      _stMsg.sText                  := concat('FB done: ', TO_STRING(_eState));

      IF (_MessageLevel = E_MessageType.eMessageVerbose)
      THEN
        f_MessageSet(_stMsg);
      END_IF
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_OCCUPIED:
    _fbMoveVelocity[2](Axis         := _AxisRef);

    IF _fbMoveVelocity[2].Error
    THEN
      _nErrorId                     := _fbMoveVelocity[2].ErrorID;
    
      _stMsg.eType                  := E_MessageType.eMessageError;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             :=  e_SubDevice.fbMoveVelocity2;
      _stMsg.iErrorNumber           := _nErrorId;
    
      _stMsg.sText                  := concat(' : ', TO_STRING(_eState));
  
      f_MessageSet(_stMsg);
    
      _eState                       := E_PROGRESS.PROGRESS_ERROR;

    ELSIF (_fbMoveVelocity[2].Velocity <> Velocity)
    THEN
      _eState                       := E_PROGRESS.PROGRESS_STARTUP;

      _fbMoveVelocity[2](
                    Axis            := _AxisRef, 
                    Execute         := FALSE);

      _stMsg.eType                  := E_MessageType.eMessageVerbose;
      _stMsg.eDevice                := e_Device.Axis + (_AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             :=  e_SubDevice.fbMoveVelocity1;
      _stMsg.iErrorNumber           := 0;

      _stMsg.sText                  := concat('Velocity changed: ', TO_STRING(_rValue));
      _stMsg.sText                  := concat(_stMsg.sText        , ' to ');
      _stMsg.sText                  := concat(_stMsg.sText        , TO_STRING(Velocity));

      IF (_MessageLevel = E_MessageType.eMessageVerbose)
      THEN
        f_MessageSet(_stMsg);
      END_IF

      _rValue                       := Velocity;
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_INIT,
  E_PROGRESS.PROGRESS_ERROR:
    _fbMoveVelocity[1](Axis         := _AxisRef,
                       Execute      := FALSE);
    _fbMoveVelocity[2](Axis         := _AxisRef,
                       Execute      := FALSE);
END_CASE


MoveVeloBuffer                      := _eState;
]]></ST>
      </Implementation>
    </Method>
    <Property Name="Override" Id="{2326350f-5459-0a6c-2ba9-357e1bba98f9}" FolderPath="properties\">
      <Declaration><![CDATA[PROPERTY Override : lreal]]></Declaration>
