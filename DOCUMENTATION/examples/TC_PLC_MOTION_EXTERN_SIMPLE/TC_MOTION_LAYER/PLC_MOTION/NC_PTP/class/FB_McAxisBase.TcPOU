    <Property Name="ErrorId" Id="{d56c7e0e-35a6-0639-16b7-19f40aaa065b}" FolderPath="properties\">
      <Declaration><![CDATA[PROPERTY ErrorId : udint]]></Declaration>
      <Get Name="Get" Id="{0b923b10-f0c2-0676-20bc-0da42dc2410d}">
