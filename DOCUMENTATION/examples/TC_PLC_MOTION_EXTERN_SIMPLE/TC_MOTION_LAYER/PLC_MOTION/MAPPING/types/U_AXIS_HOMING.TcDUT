  <DUT Name="U_AXIS_HOMING" Id="{471f2fe6-04f1-032f-118e-6ea1a17f9589}">
    <Declaration><![CDATA[TYPE U_AXIS_HOMING :
UNION

  stCtrl              : ARRAY[1..MAX_AXIS] OF ST_HOMING;

  byCtrl    AT %I*    : ARRAY[1..MAX_AXIS] OF
                        ARRAY[1..SIZEOF(ST_HOMING)] OF BYTE;
END_UNION
END_TYPE
]]></Declaration>
