<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <GVL Name="GVL_FLYING_SAW" Id="{cdeb00d4-c6c1-4276-8e8a-71679901cd15}">
    <Declaration><![CDATA[{attribute 'qualified_only'}
VAR_GLOBAL
  //-----------------------------------------------------------------------------
  // command and state structure
  //  - datafields for anyone to access
  //    - ADS via symbol
  //    - cyclic mapping to any other cyclic network/runtime
  //-----------------------------------------------------------------------------
  Ctrl                        : ARRAY[1..PLC_CONSTANT.MAX_AXIS] OF ST_FLY_CTRL;      // command structure to write into
  State                       : ARRAY[1..PLC_CONSTANT.MAX_AXIS] OF ST_FLY_STATE;     // state structure to read from


  //-----------------------------------------------------------------------------
  // data and info structure
  //  - parameter data fields for
  //    - Ctrl  --> Data
  //    - State --> Info
  //-----------------------------------------------------------------------------
//  Info                        : ARRAY[1..PLC_CONSTANT.MAX_AXIS] OF ST_FLY_INFO;
  Data                        : ARRAY[1..PLC_CONSTANT.MAX_AXIS] OF ST_FLY_DATA;


  //-----------------------------------------------------------------------------
  // R/W datafields
  // - optional data for CheckMask
  // - The Options contains two position values as limits. 
  //   The check for these position limits can be activated. 
  //   To do this, two flags 
  //   (GearInSync_CheckMask_OptionalMinPos, 
  //    GearInSync_CheckMask_OptionalMaxPos) 
  //   have to be set in the SyncMode structure.
  //
  //-----------------------------------------------------------------------------
  Options                     : ARRAY[1..PLC_CONSTANT.MAX_AXIS] OF ST_FLY_OPTIONS;


  //-----------------------------------------------------------------------------
  // cyclic interface function block: FB_FlyingCtrl
  //  - Tc2_MC2_FlyingSaw functions are here 
  //-----------------------------------------------------------------------------
{IF defined (SAW)}
  {info 'PLC_MOTION_LAYER: FLYING_SAW'}
  Control                     : ARRAY[1..PLC_CONSTANT.MAX_AXIS] OF FB_FlyingCtrl;
{ELSE}
  Control                     : ARRAY[1..PLC_CONSTANT.MAX_AXIS] OF I_Fly_Ctrl;
{END_IF}

END_VAR]]></Declaration>
  </GVL>
</TcPlcObject>