    <Method Name="Check" Id="{de78b803-16c9-4f59-bdca-564587905af4}" FolderPath="methods\private\">
      <Declaration><![CDATA[METHOD PRIVATE Check : BOOL
]]></Declaration>
      <Implementation>
        <ST><![CDATA[//-----------------------------------------------------------------------------
_szSyncMode[1]            := SIZEOF(_stOptions.SyncMode);
_szSyncMode[2]            := SIZEOF(_stSyncMode);

IF NOT (_szSyncMode[1] = _szSyncMode[2])
THEN
  _eCheck                 := E_CHECK_STATE.FLYING_OPTIONS_SYNCMODE_SIZE_NOT_EQUAL;
  RETURN;
END_IF
//-----------------------------------------------------------------------------
IF (_nAxisIndex < 1) OR
   (_nAxisIndex > PLC_CONSTANT.MAX_AXIS)
THEN
  _eCheck                 := E_CHECK_STATE.AXIS_INDEX_OUT_OF_RANGE;
  RETURN;
END_IF
//-----------------------------------------------------------------------------
IF NOT (_ItfMcAxis[_nAxisIndex] <> 0)
THEN
  _eCheck                 := E_CHECK_STATE.FLYING_SLAVE_ITF_MC_AXIS_INVALID;
  RETURN;
ELSE
  _ItfAxis                := _ItfMcAxis[_nAxisIndex];
END_IF
//-----------------------------------------------------------------------------
IF NOT (_Ctrl <> 0)
THEN
  _eCheck                 := E_CHECK_STATE.AXIS_CTRL_POINTER_INVALID;
  RETURN;
END_IF
//-----------------------------------------------------------------------------
IF NOT (_State <> 0)
THEN
  _eCheck                 := E_CHECK_STATE.AXIS_STATE_POINTER_INVALID;
  RETURN;
END_IF
//-----------------------------------------------------------------------------
IF NOT (_Data <> 0)
THEN
  _eCheck                 := E_CHECK_STATE.FLYING_FLY_DATA_POINTER_INVALID;
  RETURN;
END_IF
IF NOT (_MoveData <> 0)
THEN
  _eCheck                 := E_CHECK_STATE.FLYING_MOVE_DATA_POINTER_INVALID;
  RETURN;
END_IF
IF NOT (_Options <> 0)
THEN
  _eCheck                 := E_CHECK_STATE.FLYING_OPTIONS_POINTER_INVALID;
  RETURN;
END_IF
//-----------------------------------------------------------------------------
//  NaN INF check
//-----------------------------------------------------------------------------
IF NOT IsFinite(F_LReal(_Data^[_nAxisIndex].rDelta))
THEN
  _Data^[_nAxisIndex].rDelta              := 0.0;
END_IF

IF NOT IsFinite(F_LReal(_Data^[_nAxisIndex].rDeltaToMasterPos))
THEN
  _Data^[_nAxisIndex].rDeltaToMasterPos   := 0.0;
END_IF

IF NOT IsFinite(F_LReal(_Data^[_nAxisIndex].rGearNumerator))
THEN
  _Data^[_nAxisIndex].rGearNumerator      := 0.0;
END_IF

IF NOT IsFinite(F_LReal(_Data^[_nAxisIndex].rMasterStartDistance))
THEN
  _Data^[_nAxisIndex].rMasterStartDistance := 0.0;
END_IF

IF NOT IsFinite(F_LReal(_Data^[_nAxisIndex].rModuloSyncPosSlave))
THEN
	_Data^[_nAxisIndex].rModuloSyncPosSlave  := 0.0;
END_IF
//-----------------------------------------------------------------------------
//-----------------------------------------------------------------------------
_eCheck                   := E_CHECK_STATE.CHECK_DONE;
Check                     := TRUE;
//-----------------------------------------------------------------------------
//-----------------------------------------------------------------------------
]]></ST>
      </Implementation>
    </Method>
    <Method Name="Cmd" Id="{34ceedf2-5152-4265-9b48-73609accd4eb}" FolderPath="methods\private\">
      <Declaration><![CDATA[//-------------------------------------------------------------------------------------
//
//  HAUD 2026 06 01
//
//  Cmd
//    - gets state for ctrl
//    - checks for eInit to be done, before any other commands are accepted
//    - prepare your commands here
//    - init what you have to here
//
//-------------------------------------------------------------------------------------
METHOD PRIVATE Cmd  : E_AXIS_STATE
VAR_INPUT
  eCmd              : E_AXIS_CTRL;
END_VAR
VAR_INST
  _IdxMaster        : UDINT;
  _stMsg            : ST_Message;
  _estate           : E_AXIS_STATE;
  _eChk             : E_CHECK_STATE;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[_bError                               := FALSE;
CASE eCmd
OF
  //-------------------------------------------------------------------------------------
  E_AXIS_CTRL.AXIS_INIT:
    _eInit    := _eResult             := Init(FALSE);
    _estate                           := E_AXIS_STATE.AXIS_INIT;
ELSE
  IF (_eInit <> E_PROGRESS.PROGRESS_DONE)
  THEN
    _eResult                          := E_PROGRESS.PROGRESS_INVALID;
    _estate                           := E_AXIS_STATE.AXIS_NO_INIT;
  ELSE
    CASE eCmd
    OF
      //---------------------------------------------------------------------------------
      E_AXIS_CTRL.AXIS_IDLE:
        _eResult                      := AxisFlyIdle(FALSE);
        _estate                       := E_AXIS_STATE.AXIS_IDLE;

      //---------------------------------------------------------------------------------
      E_AXIS_CTRL.FLY_GEAR_IN_POS:
        _IdxMaster                    := GetIndex(_Data^[_nAxisIndex].nMasterAxisId);
        _nMasterIndex                 := TO_UINT(_IdxMaster);
        _stFlyData                    := _Data^[_nAxisIndex];
        _stMoveData                   := _MoveData^[_nAxisIndex];
        _stOptions                    := _Options^[_nAxisIndex];

        IF (_IdxMaster = 0)
        THEN
          _eResult                    := E_PROGRESS.PROGRESS_ERROR;
          _eChk                       := E_CHECK_STATE.FLYING_MASTER_AXIS_REF_INVALID;
  
          _stMsg.eType                := E_MessageType.eMessageError;
          _stMsg.eSubdevice           := e_Subdevice.FlyingSawControl;
          _stMsg.iErrorNumber         := _nMasterIndex;
    
          _stMsg.sText                := concat(' : ', TO_STRING(_eChk));
          f_MessageSet(_stMsg);
        ELSE
          _eChk                       := _eCheck;
          _eResult                    := AxisGearInPos(FALSE);
          _estate                     := E_AXIS_STATE.FLY_GEAR_IN_POS;
        END_IF

      //---------------------------------------------------------------------------------
      E_AXIS_CTRL.FLY_GEAR_IN_VELO:
        _IdxMaster                    := GetIndex(_Data^[_nAxisIndex].nMasterAxisId);
        _stFlyData                    := _Data^[_nAxisIndex];
        _stMoveData                   := _MoveData^[_nAxisIndex];
        _stOptions                    := _Options^[_nAxisIndex];

        IF (_IdxMaster = 0)
        THEN
          _eResult                    := E_PROGRESS.PROGRESS_ERROR;
          _eChk                       := E_CHECK_STATE.FLYING_MASTER_AXIS_REF_INVALID;
  
          _stMsg.eType                := E_MessageType.eMessageError;
          _stMsg.eSubdevice           := e_Subdevice.FlyingSawControl;
          _stMsg.iErrorNumber         := _nMasterIndex;
    
          _stMsg.sText                := concat(' : ', TO_STRING(_eChk));
          f_MessageSet(_stMsg);
        ELSE
          _eChk                       := _eCheck;
          _eResult                    := AxisGearInVelo(FALSE);
          _estate                     := E_AXIS_STATE.FLY_GEAR_IN_VELO;
        END_IF

    //-----------------------------------------------------------------------------------
    ELSE
      _estate                         := E_AXIS_STATE.AXIS_NULL;

      IF (eCmd = E_AXIS_CTRL.AXIS_NULL)
      THEN
        _eResult                      := E_PROGRESS.PROGRESS_DONE;
      ELSE
        _eResult                      := E_PROGRESS.PROGRESS_INVALID;
  
        _stMsg.eType                  := E_MessageType.eMessageError;
        _stMsg.eSubdevice             := e_Subdevice.FlyingSawControl;
        _stMsg.iErrorNumber           := 0;
  
        _stMsg.sText                  := 'E_AXIS_CTRL.';
        _stMsg.sText                  := concat(_stMsg.sText, TO_STRING(eCmd));
        _stMsg.sText                  := concat(_stMsg.sText, ': ');
        _stMsg.sText                  := concat(_stMsg.sText, TO_STRING(_eResult));

        f_MessageSet(_stMsg);
      END_IF
    END_CASE
  END_IF // _eInit
END_CASE

Cmd                                   := _estate;

]]></ST>
      </Implementation>
    </Method>
    <Method Name="Cycle" Id="{42d67df9-ee61-4346-b784-f255339c4e2f}" FolderPath="methods\">
      <Declaration><![CDATA[METHOD Cycle  : e_progress
VAR_INST
  _eCycle     : E_PROGRESS;

  _eCheckOld  : E_CHECK_STATE;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT Check() THEN Cycle := _eCycle := _eResult := E_PROGRESS.PROGRESS_ERROR; END_IF
//-----------------------------------------------------------------------------
//  set message device
//-----------------------------------------------------------------------------
_stMsg.eDevice                      := e_Device.FlyingSaw + (_ItfAxis.AxisRef.NcToPlc.AxisId);
//-----------------------------------------------------------------------------
//-----------------------------------------------------------------------------
// OnChange log _eCheck; in case of error --> return to caller
//-----------------------------------------------------------------------------
IF (_eCheck <> _eCheckOld)
THEN
  LogCheck();
  _eCheckOld                        := _eCheck;
END_IF
//-----------------------------------------------------------------------------
IF NOT (_eCheck = E_CHECK_STATE.CHECK_DONE)
THEN
  RETURN;
END_IF
//-----------------------------------------------------------------------------
//-----------------------------------------------------------------------------
// get command from outside world
//-----------------------------------------------------------------------------
_eCmd                               := _Ctrl^[_nAxisIndex].eCmd;
//-----------------------------------------------------------------------------
//-----------------------------------------------------------------------------
//  OnChange react to command
//-----------------------------------------------------------------------------
IF (_eCmd <> _eCmdOld)
THEN
  // get busy
  _eState                           := Cmd(_eCmd); // get execution state for command
  _eCmdOld                          := _eCmd;
  LogControl();
END_IF
//-----------------------------------------------------------------------------
//-----------------------------------------------------------------------------
//  execution result
//-----------------------------------------------------------------------------
CASE _eResult
OF
  E_PROGRESS.PROGRESS_INVALID:
    _State^[_nAxisIndex].eState     := TO_UINT(E_PROGRESS.PROGRESS_ERROR);

  E_PROGRESS.PROGRESS_ERROR:
    _State^[_nAxisIndex].eState     := _eState + E_PROGRESS.PROGRESS_ERROR;

  E_PROGRESS.PROGRESS_DONE:
    _State^[_nAxisIndex].eState     := _eState + E_PROGRESS.PROGRESS_DONE;

ELSE
    _State^[_nAxisIndex].eState     := _eState + _eResult;
  //-----------------------------------------------------------------------------
  //-----------------------------------------------------------------------------
  //  execution state for command
  //-----------------------------------------------------------------------------
  CASE _eState
  OF
    //---------------------------------------------------------------------------
    E_AXIS_STATE.AXIS_INIT:
      // axis always requires one init from outside world at startup
      // _eInit has to be valid for other commands to be accepted in Cmd(_eCtrl)
      _eInit := _eResult            := Init(TRUE);
  
    //---------------------------------------------------------------------------
    E_AXIS_STATE.AXIS_NO_INIT:
      // we are here because you sent a command before having done INIT
      _eResult                      := E_PROGRESS.PROGRESS_ERROR;
  
    //---------------------------------------------------------------------------
    E_AXIS_STATE.AXIS_IDLE:
      _eResult                      := AxisFlyIdle(TRUE);
  
    //---------------------------------------------------------------------------
    E_AXIS_STATE.FLY_GEAR_IN_POS:
      _eResult                      := AxisGearInPos(TRUE);
  
    //---------------------------------------------------------------------------
    E_AXIS_STATE.FLY_GEAR_IN_VELO:
      _eResult                      := AxisGearInVelo(TRUE);

  ELSE
    IF (_eCmd > E_AXIS_CTRL.AXIS_NULL)
    THEN
      _eResult                      := E_PROGRESS.PROGRESS_NOT_EXIST;
    ELSE
      _eResult                      := E_PROGRESS.PROGRESS_INVALID;
    END_IF
  END_CASE
END_CASE
//-----------------------------------------------------------------------------
//-----------------------------------------------------------------------------
//  OnChange of execution state result
//    - log result and clear error number on interface
//-----------------------------------------------------------------------------
IF (_eResult <> _eResultOld)
THEN
  LogResult();
  _eResultOld                       := _eResult;
END_IF
//-----------------------------------------------------------------------------

]]></ST>
      </Implementation>
    </Method>
    <Property Name="GearData" Id="{009ad625-b437-4696-90eb-ecec7681cf27}" FolderPath="properties\">
      <Declaration><![CDATA[PROPERTY GearData : pointer to ARRAY[1..PLC_CONSTANT.MAX_AXIS] OF ST_FLY_DATA]]></Declaration>
      <Set Name="Set" Id="{c5f75036-ced2-4337-9632-151de3fecd47}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[_Data := GearData;
]]></ST>
        </Implementation>
      </Set>
    </Property>
    <Method Name="GetIndex" Id="{6571a6a5-e778-4660-86ba-80099bd0cd9b}" FolderPath="methods\">
      <Declaration><![CDATA[METHOD GetIndex : udint
VAR_INPUT
  AxisId        : UDINT;
END_VAR
VAR
  _nidx         : UDINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT Check() THEN GetIndex := 0; RETURN; END_IF

FOR _nidx := 1 TO PLC_CONSTANT.MAX_AXIS
DO
  IF (_ItfMcAxis[_nidx].AxisRef.NcToPlc.AxisId = AxisId)
  THEN
    GetIndex      := _nIdx;
    RETURN;
  END_IF
END_FOR

GetIndex          := 0;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="Init" Id="{59da1c9f-a26d-40f1-9bdb-cee24cfbc241}" FolderPath="methods\private\">
      <Declaration><![CDATA[METHOD PRIVATE Init : E_PROGRESS
VAR_INPUT
  Execute           : BOOL;
END_VAR
VAR_INST
  _eResult,
  _eState           : E_PROGRESS;
  _rValue           : LREAL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT Execute THEN Init := _estate := E_PROGRESS.PROGRESS_INIT; END_IF
IF NOT Check() THEN Init := _estate := E_PROGRESS.PROGRESS_ERROR; END_IF

CASE _eState
OF
  E_PROGRESS.PROGRESS_INIT:
    IF Execute 
    THEN
      memset(ADR(_stMsg),0,SIZEOF(_stMsg));

      _nErrorId                     := 0;
      _rValue                       := 0;
      _eState                       := E_PROGRESS.PROGRESS_BUSY;
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_BUSY:
    _eState                         := E_PROGRESS.PROGRESS_STARTUP;
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_STARTUP:
    // keep this for future use
    _eResult                        := E_PROGRESS.PROGRESS_DONE;//StartUp(TRUE);
    IF (_eResult = E_PROGRESS.PROGRESS_DONE)
    THEN
      _eState                       := E_PROGRESS.PROGRESS_PREPARE;
      _ItfMcAxis[_nAxisIndex].Reset(FALSE);
    ELSIF (_eResult = E_PROGRESS.PROGRESS_ERROR)
    THEN
      _eState                       := _eResult;

      _stMsg.eType                  := E_MessageType.eMessageError;
      _stMsg.eDevice                := e_Device.FlyingSaw + (_ItfAxis.AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             := e_Subdevice.FlyingSawStartUp;
      _stMsg.iErrorNumber := _nErrorId  := 6666;

      _stMsg.sText                  := TO_STRING(_eState);
      f_MessageSet(_stMsg);
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_PREPARE:
    _eResult                        := _ItfMcAxis[_nAxisIndex].Reset(TRUE);
    IF (_eResult = E_PROGRESS.PROGRESS_DONE)
    THEN
      _eState                       := E_PROGRESS.PROGRESS_CHECK;
    ELSIF (_eResult = E_PROGRESS.PROGRESS_ERROR)
    THEN
      _eState                       := _eResult;

      _stMsg.eType                  := E_MessageType.eMessageError;
      _stMsg.eDevice                := e_Device.FlyingSaw + (_ItfAxis.AxisRef.NcToPlc.AxisId);
      _stMsg.eSubdevice             := e_Subdevice.fbReset;
      _stMsg.iErrorNumber           := _ItfAxis.AxisRef.Status.ErrorID;

      _stMsg.sText                  := TO_STRING(_eState);
      f_MessageSet(_stMsg);
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_CHECK:
    _eResult                        := _ItfMcAxis[_nAxisIndex].Reset(FALSE);
    _eState                         := E_PROGRESS.PROGRESS_OCCUPIED;
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_OCCUPIED:
    _eState                         := E_PROGRESS.PROGRESS_WORKING;
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_WORKING:
    _eState                         := E_PROGRESS.PROGRESS_DONE;

    _stMsg.eType                    := E_MessageType.eMessageInfo;
    _stMsg.eSubdevice               := e_Subdevice.FlyingSawControl;
    _stMsg.iErrorNumber             := 0;
    _stMsg.sText                    := concat('Init: ', TO_STRING(_eState));

    IF (_MessageLevel < E_MessageType.eMessageError)
    THEN
      f_MessageSet(_stMsg);
    END_IF
END_CASE

Init                                := _eState;
]]></ST>
      </Implementation>
    </Method>
    <Property Name="ItfMcAxes" Id="{93bc5d57-cdec-4692-a5aa-630eb1c888cd}" FolderPath="properties\">
      <Declaration><![CDATA[PROPERTY ItfMcAxes : array[1..MAX_AXIS] of I_McAxis]]></Declaration>
      <Set Name="Set" Id="{2c1ce229-97ee-4882-b83c-457576795638}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[_ItfMcAxis := ItfMcAxes;
]]></ST>
        </Implementation>
      </Set>
    </Property>
    <Method Name="LogCheck" Id="{46c74da4-d3fa-4537-a28d-6d74180013eb}" FolderPath="methods\private\">
      <Declaration><![CDATA[METHOD LogCheck
VAR_INST
  _sChck            : STRING(40);
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[  _stMsg.eType               := SEL((_eCheck = E_CHECK_STATE.CHECK_DONE),(E_MessageType.eMessageError),(E_MessageType.eMessageInfo));
  _stMsg.eSubdevice          := e_Subdevice.FlyingSawControl;
  _stMsg.iErrorNumber        := _nAxisIndex;

  _sChck                     := concat('E_CHECK_STATE', '.');
  _sChck                     := concat(_sChck, TO_STRING(_eCheck));

  _stMsg.sText               := concat('cyclic check: ', _sChck);

  IF (_MessageLevel > E_MessageType.eMessageError)
  THEN
    f_MessageSet(_stMsg);
  ELSE
    IF (_stMsg.eType = E_MessageType.eMessageError)
    THEN
      f_MessageSet(_stMsg);
    END_IF
  END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="LogControl" Id="{9cf6aeaf-d5e0-49c4-86eb-d32ce2cdcd8e}" FolderPath="methods\private\">
      <Declaration><![CDATA[METHOD PRIVATE LogControl
VAR_INST
  _sResult,
  _sCtrl            : STRING(40);
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[  _stMsg.eType               := E_MessageType.eMessageInfo;
  _stMsg.eDevice             := E_Device.FlyingSaw + (_ItfAxis.AxisRef.NcToPlc.AxisId);
  _stMsg.eSubdevice          := e_Subdevice.FlyingSawControl;
  _stMsg.iErrorNumber        := _nAxisIndex;

  _sCtrl                     := concat('E_AXIS_CTRL', '.');
  _sCtrl                     := concat(_sCtrl, TO_STRING(_eCmd));

  _stMsg.sText               := concat('new command: ', _sCtrl);

  IF (_MessageLevel > E_MessageType.eMessageError)
  THEN
    f_MessageSet(_stMsg);
  ELSE
    IF (_stMsg.eType = E_MessageType.eMessageError)
    THEN
      f_MessageSet(_stMsg);
    END_IF
  END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="LogResult" Id="{53935a62-e7c2-4893-a66f-4257b423c150}" FolderPath="methods\private\">
      <Declaration><![CDATA[METHOD PRIVATE LogResult
VAR_INST
  _sResult,
  _sCtrl            : STRING(40);
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[  _stMsg.eType               := E_MessageType.eMessageInfo;
  _stMsg.eDevice             := E_Device.FlyingSaw + (_ItfAxis.AxisRef.NcToPlc.AxisId);
  _stMsg.eSubdevice          := e_Subdevice.FlyingSawControl;
  _stMsg.iErrorNumber        := _nAxisIndex;

  _sCtrl                     := concat('E_AXIS_CTRL', '.');
  _sCtrl                     := concat(_sCtrl, TO_STRING(_eCmdOld));

  _sResult                   := concat(': E_PROGRESS', '.');
  _sResult                   := concat(_sResult, TO_STRING(_eResult));

  _stMsg.sText               := concat(_sCtrl, ' ');
  _stMsg.sText               := concat(_sCtrl, _sResult);

  IF (_MessageLevel > E_MessageType.eMessageError)
  THEN
    f_MessageSet(_stMsg);
  ELSE
    IF (_stMsg.eType = E_MessageType.eMessageError)
    THEN
      f_MessageSet(_stMsg);
    END_IF
  END_IF
]]></ST>
      </Implementation>
    </Method>
