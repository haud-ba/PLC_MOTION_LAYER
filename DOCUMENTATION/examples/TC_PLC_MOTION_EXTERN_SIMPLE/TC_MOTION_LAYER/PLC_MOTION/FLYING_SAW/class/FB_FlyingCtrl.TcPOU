    <Method Name="AxisFlyIdle" Id="{2de65bce-7d05-4392-ac3b-c24a275f86d6}" FolderPath="methods\">
      <Declaration><![CDATA[METHOD AxisFlyIdle : E_PROGRESS
VAR_INPUT
  Execute           : BOOL;
END_VAR
VAR_INST
  _eResult,
  _eState           : E_PROGRESS;
  _nRetry           : UINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT Execute THEN _eState := E_PROGRESS.PROGRESS_INIT; END_IF
IF NOT Check() THEN _eState := E_PROGRESS.PROGRESS_ERROR; END_IF

CASE _eState
OF
  E_PROGRESS.PROGRESS_INIT:
    IF Execute 
    THEN
      memset(ADR(_stMsg),0,SIZEOF(_stMsg));
      _nRetry                       := 0;
      _eResult                      := _ItfAxis.Reset(FALSE);
      _eState                       := E_PROGRESS.PROGRESS_BUSY;
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_PREPARE:
    _nRetry                         := _nRetry + 1;
    _eResult                        := _ItfAxis.Reset(FALSE);
    _eResult                        := _ItfAxis.Enable(FALSE);

    _eState                         := E_PROGRESS.PROGRESS_BUSY;

    _stMsg.eType                    := E_MessageType.eMessageInfo;
    _stMsg.eSubdevice               :=  e_SubDevice.fbPower;
    _stMsg.iErrorNumber             := _nErrorId;

    _stMsg.sText                    := concat(TO_STRING(_eCmd), ' retry: ');
    _stMsg.sText                    := concat(_stMsg.sText, TO_STRING(_nRetry));

    IF (_MessageLevel < E_MessageType.eMessageError)
    THEN
      f_MessageSet(_stMsg);
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_BUSY:
    _eResult                        := _ItfAxis.Reset(TRUE);

    IF (_eResult = E_PROGRESS.PROGRESS_DONE)
    THEN
      _eState                       := E_PROGRESS.PROGRESS_STARTUP;
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_STARTUP:
    _eResult                        := _ItfAxis.Reset(FALSE);
    _eResult                        := _ItfAxis.Enable(FALSE);
    _eState                         := E_PROGRESS.PROGRESS_CHECK;
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_CHECK:
    _eResult                        := _ItfAxis.Enable(TRUE);

    IF (_nRetry > MAX_RETRY)
    THEN
      _eState                       := E_PROGRESS.PROGRESS_ERROR;

    ELSIF (_eResult = E_PROGRESS.PROGRESS_DONE)
    THEN
      _ItfAxis.Enable(FALSE);
      _eState                       := E_PROGRESS.PROGRESS_DONE;

    ELSIF (_eResult = E_PROGRESS.PROGRESS_ERROR)
    THEN
      _eState                       := E_PROGRESS.PROGRESS_PREPARE;

      _nErrorId                     := _ItfAxis.AxisRef.NcToPlc.ErrorCode;
    
      _stMsg.eType                  := E_MessageType.eMessageError;
      _stMsg.eSubdevice             :=  e_SubDevice.fbPower;
      _stMsg.iErrorNumber           := _nErrorId;

      _stMsg.sText                  := concat(TO_STRING(_eCmd), ' error axis enable: ');
      _stMsg.sText                  := concat(_stMsg.sText, TO_STRING(_nAxisIndex));

      f_MessageSet(_stMsg);
    END_IF
END_CASE

AxisFlyIdle                         := _eState;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AxisGearInPos" Id="{71c04c16-79c5-48dd-acd5-fab8e6ff56e4}" FolderPath="methods\">
      <Declaration><![CDATA[METHOD AxisGearInPos : E_PROGRESS
VAR_INPUT
  Execute           : BOOL;
END_VAR
VAR_INST
  _eCk              : E_CHECK_STATE;

  _eResult,
  _eState           : E_PROGRESS;
  _rValue           : LREAL;
  _udiErr           : UDINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT Execute THEN _eState := E_PROGRESS.PROGRESS_INIT; END_IF
IF NOT Check() THEN _eState := E_PROGRESS.PROGRESS_ERROR; END_IF


CASE _eState
OF
  E_PROGRESS.PROGRESS_INIT:
    IF Execute 
    THEN
      _udiErr                       := 0;

      IF NOT (_nMasterIndex > 0) OR
         NOT (_nMasterIndex < PLC_CONSTANT.MAX_AXIS+1)
      THEN
        _eState                     := E_PROGRESS.PROGRESS_ERROR;
        _eCk                        := E_CHECK_STATE.FLYING_MASTER_AXIS_REF_INVALID;

        _stMsg.eType                := E_MessageType.eMessageError;
        _stMsg.eSubdevice           := e_Subdevice.FlyingSawControl;
        _stMsg.iErrorNumber         := _nMasterIndex;
  
        _stMsg.sText                := concat(' : ', TO_STRING(_eCk));
        f_MessageSet(_stMsg);

      ELSE
        _Master                     ref= _ItfMcAxis[_nMasterIndex].AxisRef;
        _eState                     := E_PROGRESS.PROGRESS_BUSY;
        _eCk                        := E_CHECK_STATE.CHECK_DONE;
        _eResult                    := GearInPos(FALSE, _stMoveData, _stFlyData, _stOptions);
      END_IF
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_BUSY:
      _eResult                      := GearInPos(TRUE, _stMoveData, _stFlyData, _stOptions);

    IF (_eResult = E_PROGRESS.PROGRESS_ERROR) OR
       (_eResult = E_PROGRESS.PROGRESS_OCCUPIED)
    THEN
      GearInPos(FALSE, _stMoveData, _stFlyData, _stOptions);
      _eState                       := E_PROGRESS.PROGRESS_ERROR;
      _udiErr                       := _fbGearInPos.ErrorID;

    ELSIF (_eResult = E_PROGRESS.PROGRESS_DONE)
    THEN
      GearInPos(FALSE, _stMoveData, _stFlyData, _stOptions);
      _eState                       := E_PROGRESS.PROGRESS_DONE;
    END_IF
END_CASE


AxisGearInPos                       := _eState;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="AxisGearInVelo" Id="{f89388fd-0194-475a-bd5e-5079adb322f2}" FolderPath="methods\">
      <Declaration><![CDATA[METHOD AxisGearInVelo : E_PROGRESS
VAR_INPUT
  Execute           : BOOL;
END_VAR
VAR_INST
  _eCk              : E_CHECK_STATE;

  _eResult,
  _eState           : E_PROGRESS;
  _rValue           : LREAL;
  _udiErr           : UDINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT Execute THEN _eState := E_PROGRESS.PROGRESS_INIT; END_IF
IF NOT Check() THEN _eState := E_PROGRESS.PROGRESS_ERROR; END_IF


CASE _eState
OF
  E_PROGRESS.PROGRESS_INIT:
    IF Execute 
    THEN
      _udiErr                       := 0;

      IF NOT (_nMasterIndex > 0) OR
         NOT (_nMasterIndex < PLC_CONSTANT.MAX_AXIS+1)
      THEN
        _eState                     := E_PROGRESS.PROGRESS_ERROR;
        _eCk                        := E_CHECK_STATE.FLYING_MASTER_AXIS_REF_INVALID;

        _stMsg.eType                := E_MessageType.eMessageError;
        _stMsg.eSubdevice           := e_Subdevice.FlyingSawControl;
        _stMsg.iErrorNumber         := _nMasterIndex;
  
        _stMsg.sText                := concat(' : ', TO_STRING(_eCk));
        f_MessageSet(_stMsg);

      ELSE
        _eState                     := E_PROGRESS.PROGRESS_BUSY;
        _eCk                        := E_CHECK_STATE.CHECK_DONE;
        _eResult                    := GearInVelo(FALSE, _stMoveData, _stFlyData, _stOptions);
      END_IF
    END_IF
END_CASE
CASE _eState
OF
  E_PROGRESS.PROGRESS_BUSY:
      _eResult                      := GearInVelo(TRUE, _stMoveData, _stFlyData, _stOptions);

    IF (_eResult = E_PROGRESS.PROGRESS_ERROR)
    THEN
      GearInVelo(FALSE, _stMoveData, _stFlyData, _stOptions);
      _eState                       := E_PROGRESS.PROGRESS_ERROR;
      _udiErr                       := _fbGearInVelo.ErrorID;

    ELSIF (_eResult = E_PROGRESS.PROGRESS_DONE)
    THEN
      GearInVelo(FALSE, _stMoveData, _stFlyData, _stOptions);
      _eState                       := E_PROGRESS.PROGRESS_DONE;
    END_IF
END_CASE


AxisGearInVelo                      := _eState;
]]></ST>
      </Implementation>
    </Method>
