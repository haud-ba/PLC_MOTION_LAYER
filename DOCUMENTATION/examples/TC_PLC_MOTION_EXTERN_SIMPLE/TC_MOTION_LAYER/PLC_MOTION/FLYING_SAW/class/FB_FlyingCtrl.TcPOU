<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="FB_FlyingCtrl" Id="{06eb0893-79e7-4f8a-a3bd-cfe30fd2aa02}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_FlyingCtrl EXTENDS FB_FlyingBase IMPLEMENTS I_Fly_Ctrl
VAR
  _eInit                    : E_PROGRESS;
  _nAxisIndex               : UINT;       // know thyself
  _nMasterIndex             : UINT;       // to whom must I answer?

  // get interface from McAxis for access to Reset, Enable, Disable, Halt
  _ItfMcAxis                : ARRAY[1..PLC_CONSTANT.MAX_AXIS] OF I_McAxis;

  // pointers to all; access required for coupling; access by index
  _Ctrl                     : POINTER TO ARRAY[1..PLC_CONSTANT.MAX_AXIS] OF ST_FLY_CTRL;    // contains command to be executed
  _State                    : POINTER TO ARRAY[1..PLC_CONSTANT.MAX_AXIS] OF ST_FLY_STATE;   // mirrors command with added result

  //_Info                     : POINTER TO ARRAY[1..PLC_CONSTANT.MAX_AXIS] OF ST_FLY_INFO;    // Read Info Data
  _Data                     : POINTER TO ARRAY[1..PLC_CONSTANT.MAX_AXIS] OF ST_FLY_DATA;    // fLYINGsAW parameters

  _MoveData                 : POINTER TO ARRAY[1..PLC_CONSTANT.MAX_AXIS] OF ST_MOVE_DATA;   // dynamic parameters

  _Options                  : POINTER TO ARRAY[1..PLC_CONSTANT.MAX_AXIS] OF ST_FLY_OPTIONS; // gear in slave options

  // local copies of command
  _eCmd,
  _eCmdOld                  : E_AXIS_CTRL;

  // execution state
  _eResult                  : E_PROGRESS;   // result of execution state
  _eResultOld               : E_PROGRESS;   // old result for detecting change
  _eState                   : E_AXIS_STATE; // execution state
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Folder Name="methods" Id="{f4bdc416-e3b8-4db7-82c2-906af4d53ecc}">
